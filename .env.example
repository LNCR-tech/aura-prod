# Copy this file to .env for local development.
# Keep real secrets out of version control.

# -----------------------------------------------------------------------------
# Core infrastructure
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=fastapi_db

# Local backend host defaults. Docker Compose service-level overrides still apply.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/fastapi_db
DATABASE_ADMIN_URL=postgresql://postgres:postgres@127.0.0.1:5433/postgres
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
CELERY_TASK_TIME_LIMIT_SECONDS=10800
UVICORN_WORKERS=2

# -----------------------------------------------------------------------------
# Backend API
# -----------------------------------------------------------------------------
SECRET_KEY=change-this-secret-before-production
JWT_SECRET=change-this-secret-before-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!

DB_POOL_SIZE=10
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT_SECONDS=15
DB_POOL_RECYCLE_SECONDS=1800

FACE_SCAN_BYPASS_ALL=false
FACE_SCAN_BYPASS_EMAILS=
FACE_THRESHOLD_SINGLE=0.40
FACE_THRESHOLD_GROUP=0.40
FACE_THRESHOLD_MFA=0.35
FACE_EMBEDDING_DIM=512
FACE_EMBEDDING_DTYPE=float32
LIVENESS_THRESHOLD=0.85
ALLOW_LIVENESS_BYPASS_WHEN_MODEL_MISSING=false
ANTI_SPOOF_SCALE=2.7
ANTI_SPOOF_MODEL_PATH=
GEO_MAX_ALLOWED_ACCURACY_M=30
GEO_MAX_TRAVEL_SPEED_MPS=60

EVENT_STATUS_SYNC_ENABLED=true
EVENT_STATUS_SYNC_INTERVAL_SECONDS=60
PUBLIC_ATTENDANCE_ENABLED=true
PUBLIC_ATTENDANCE_MAX_FACES_PER_FRAME=10
PUBLIC_ATTENDANCE_SCAN_COOLDOWN_SECONDS=8
PUBLIC_ATTENDANCE_EVENT_LOOKAHEAD_HOURS=12
TENANT_DATABASE_PREFIX=school

IMPORT_MAX_FILE_SIZE_MB=50
IMPORT_CHUNK_SIZE=5000
IMPORT_STORAGE_DIR=storage/imports
IMPORT_RATE_LIMIT_COUNT=3
IMPORT_RATE_LIMIT_WINDOW_SECONDS=300

# Email transport (set EMAIL_TRANSPORT=smtp for local Mailpit, or gmail_api for Google OAuth delivery)
EMAIL_TRANSPORT=disabled
EMAIL_REQUIRED_ON_STARTUP=false
EMAIL_VERIFY_CONNECTION_ON_STARTUP=false
EMAIL_TIMEOUT_SECONDS=20
EMAIL_SENDER_EMAIL=notifications@example.com
EMAIL_FROM_EMAIL=notifications@example.com
EMAIL_FROM_NAME=VALID8 Notifications
EMAIL_REPLY_TO=notifications@example.com

# SMTP transport settings (used when EMAIL_TRANSPORT=smtp)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
SMTP_USE_STARTTLS=false

# Gmail API transport settings (used when EMAIL_TRANSPORT=gmail_api)
EMAIL_GOOGLE_ACCOUNT_TYPE=personal
EMAIL_GOOGLE_ALLOW_CUSTOM_FROM=false
GOOGLE_GMAIL_API_BASE_URL=https://gmail.googleapis.com/gmail/v1
GOOGLE_OAUTH_AUTH_URL=https://accounts.google.com/o/oauth2/auth
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_OAUTH_REFRESH_TOKEN=your-google-oauth-refresh-token
GOOGLE_OAUTH_SCOPES=https://www.googleapis.com/auth/gmail.send,https://www.googleapis.com/auth/gmail.settings.basic
GOOGLE_OAUTH_TOKEN_URL=https://oauth2.googleapis.com/token

LOGIN_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

SCHOOL_LOGO_STORAGE_DIR=storage/school_logos
SCHOOL_LOGO_MAX_FILE_SIZE_MB=2
SCHOOL_LOGO_PUBLIC_PREFIX=/media/school-logos

# -----------------------------------------------------------------------------
# Assistant service
# -----------------------------------------------------------------------------
# For local standalone assistant runs:
TENANT_DATABASE_URL=postgresql://postgres:postgres@localhost:5433/fastapi_db
APP_DATABASE_URL=postgresql://postgres:postgres@localhost:5433/fastapi_db
ASSISTANT_DB_URL=postgresql://postgres:postgres@localhost:5433/ai_assistant
ASSISTANT_DB_SCHEMA=public
ASSISTANT_AUTO_MIGRATE=true
ASSISTANT_CONTEXT_MAX_MESSAGES=

# AI configuration used by Assistant (provider-agnostic, OpenAI-compatible HTTP API)
AI_MODEL=deepseek-ai/DeepSeek-V3.2
AI_API_KEY=replace_me
AI_API_BASE=https://api.siliconflow.com/v1
AI_MAX_TOKENS=16384

# Legacy aliases (still supported, but prefer LLM_* above)
OPENAI_MODEL=
OPENAI_API_KEY=
OPENAI_API_BASE=
OPENAI_MAX_TOKENS=

# Optional MCP endpoints (assistant defaults already exist in code)
MCP_SCHEMA_URL=http://127.0.0.1:8500/mcp/schema/schema
MCP_QUERY_URL=http://127.0.0.1:8500/mcp/query/query
MCP_SCHOOL_ADMIN_URL=http://127.0.0.1:8500/mcp/school-admin/action
MCP_STUDENT_IMPORT_URL=http://127.0.0.1:8500/mcp/student-import/action
ASSISTANT_VERSION=v2
ASSISTANT_PORT=8500

# -----------------------------------------------------------------------------
# Frontend build/runtime
# -----------------------------------------------------------------------------
# Vite build-time variables
VITE_API_BASE_URL=/__backend__
VITE_API_TIMEOUT_MS=15000
VITE_ASSISTANT_BASE_URL=/__assistant__
VITE_NATIVE_API_BASE_URL=http://localhost:8000
VITE_BACKEND_PROXY_TARGET=

# Docker runtime variables for nginx proxy/runtime-config
BACKEND_ORIGIN=http://backend:8000
ASSISTANT_ORIGIN=http://assistant:8500
AURA_API_BASE_URL=/__backend__
AURA_API_TIMEOUT_MS=15000
AURA_ASSISTANT_BASE_URL=/__assistant__
FRONTEND_PORT=5173
# -----------------------------------------------------------------------------
# Development & Seeding
# -----------------------------------------------------------------------------
# If true, the seeder will populate the database with ~100 demo users/students.
# If false, only one default admin will be created.
SEED_DATABASE=true
SEED_DEMO_SCHOOLS=5
SEED_DEMO_USERS=100

# Default School Configuration
DEFAULT_SCHOOL_NAME=Default School
DEFAULT_SCHOOL_CODE=DS-001
DEFAULT_SCHOOL_ADDRESS=Default Address

# Massive Seeding Mode (1M+ Records for stress testing)
# If SEED_MASSIVE_ATTENDANCE=true, SEED_DATABASE must also be true.
SEED_MASSIVE_ATTENDANCE=false
SEED_MASSIVE_STUDENTS=5000
SEED_MASSIVE_RECORDS=1000000

# Wipe Logic (Clear all records before seeding)
SEED_WIPE_EXISTING=false
