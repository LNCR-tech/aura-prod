# Aura root environment file
#
# Copy this file to `.env` when running from the repo root.
# This file is for backend, assistant, worker/beat, and repo-root Docker Compose.
# Frontend Vite dev uses `frontend/.env.development.local` instead.

# =============================================================================
# Local setup
# =============================================================================

# -----------------------------------------------------------------------------
# Local setup -> variables that apply to both manual and Docker
# -----------------------------------------------------------------------------

# Required
SECRET_KEY=change-this-secret-before-production
AI_API_KEY=replace-with-your-ai-api-key
AI_API_BASE=replace-with-your-provider-base-url
AI_MODEL=replace-with-your-provider-model

# Optional
JWT_ALGORITHM=HS256
JWT_PUBLIC_KEY=
PRIVILEGED_FACE_VERIFICATION_ENABLED=true

# Optional overall, but conditionally required when EMAIL_TRANSPORT is enabled (smtp or mailjet_api).
EMAIL_TRANSPORT=disabled
EMAIL_SENDER_EMAIL=notifications@example.com
EMAIL_SENDER_NAME=Aura Notifications
EMAIL_REPLY_TO=notifications@example.com
MAILJET_API_KEY=
MAILJET_API_SECRET=

# -----------------------------------------------------------------------------
# Local setup -> manual -> required variables
# -----------------------------------------------------------------------------

DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/fastapi_db
ASSISTANT_DB_URL=postgresql://postgres:postgres@127.0.0.1:5432/ai_assistant
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
BACKEND_API_BASE_URL=http://127.0.0.1:8000

# -----------------------------------------------------------------------------
# Local setup -> manual -> optional variables
# -----------------------------------------------------------------------------

ASSISTANT_AUTO_MIGRATE=true
LOGIN_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
UVICORN_WORKERS=1

# Conditionally required when EMAIL_TRANSPORT=smtp
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USE_TLS=false
SMTP_USE_STARTTLS=false
SMTP_USERNAME=
SMTP_PASSWORD=

# -----------------------------------------------------------------------------
# Local setup -> Docker -> required variables
# -----------------------------------------------------------------------------

# Required for the current repo-root Docker Compose flow:
# - none beyond the shared local values above
#
# Important: the current repo-root docker-compose.yml hardcodes local container
# URLs for Postgres, Redis, backend, and assistant. Root `.env` does not
# override those service URLs today.

# -----------------------------------------------------------------------------
# Local setup -> Docker -> optional variables
# -----------------------------------------------------------------------------

FRONTEND_PORT=5173
EMAIL_TRANSPORT=disabled
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USE_TLS=false
SMTP_USE_STARTTLS=false
SMTP_USERNAME=
SMTP_PASSWORD=
UVICORN_WORKERS=1

# -----------------------------------------------------------------------------
# Production setup
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Production setup -> variables that apply to both manual and Docker
# -----------------------------------------------------------------------------

# Required
# SECRET_KEY=replace-with-a-production-secret
# AI_API_KEY=replace-with-your-production-ai-api-key
# AI_API_BASE=replace-with-your-production-provider-base-url
# AI_MODEL=replace-with-your-production-provider-model

# Optional
# JWT_ALGORITHM=HS256
# JWT_PUBLIC_KEY=
# PRIVILEGED_FACE_VERIFICATION_ENABLED=true

# Optional overall, but conditionally required when EMAIL_TRANSPORT is enabled (smtp or mailjet_api).
# EMAIL_TRANSPORT=disabled
# EMAIL_SENDER_EMAIL=notifications@example.com
# EMAIL_SENDER_NAME=Aura Notifications
# EMAIL_REPLY_TO=notifications@example.com
# MAILJET_API_KEY=
# MAILJET_API_SECRET=

# -----------------------------------------------------------------------------
# Production setup -> manual -> required variables
# -----------------------------------------------------------------------------

# DATABASE_URL=postgresql://user:password@db-host:5432/fastapi_db
# ASSISTANT_DB_URL=postgresql://user:password@db-host:5432/ai_assistant
# CELERY_BROKER_URL=redis://redis-host:6379/0
# CELERY_RESULT_BACKEND=redis://redis-host:6379/0
# BACKEND_API_BASE_URL=https://your-backend.example.com

# -----------------------------------------------------------------------------
# Production setup -> manual -> optional variables
# -----------------------------------------------------------------------------

# ASSISTANT_AUTO_MIGRATE=false
# LOGIN_URL=https://your-frontend.example.com
# CORS_ALLOWED_ORIGINS=https://your-frontend.example.com
# UVICORN_WORKERS=2
#
# Conditionally required when EMAIL_TRANSPORT=smtp
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USE_TLS=false
# SMTP_USE_STARTTLS=true
# SMTP_USERNAME=
# SMTP_PASSWORD=

# -----------------------------------------------------------------------------
# Production setup -> Docker -> required variables
# -----------------------------------------------------------------------------

# The current repo-root docker-compose.yml is local-stack oriented and hardcodes
# internal service URLs such as:
# - DATABASE_URL=postgresql://postgres:postgres@db:5432/fastapi_db
# - CELERY_BROKER_URL=redis://redis:6379/0
# - BACKEND_API_BASE_URL=http://backend:8000
#
# For a real production Docker deployment against external infra, update the
# compose file first or use a deployment-specific compose override.

# -----------------------------------------------------------------------------
# Production setup -> Docker -> optional variables
# -----------------------------------------------------------------------------

# FRONTEND_PORT=5173
# EMAIL_TRANSPORT=disabled
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USE_TLS=false
# SMTP_USE_STARTTLS=true
# SMTP_USERNAME=
# SMTP_PASSWORD=
# UVICORN_WORKERS=2

# =============================================================================
# Frontend note
# =============================================================================
#
# Do not put Vite dev variables in this root file.
# Use one of these instead:
# - `frontend/.env.development.local` for manual `npm run dev`
# - `frontend/.env.docker` for the standalone frontend Docker setup
