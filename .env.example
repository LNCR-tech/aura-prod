-- Active: 1774646751020@@127.0.0.1@5433@fastapi_db
# Copy this file to `.env` and set real secrets before deployment.
# Non-secret backend defaults now live in `Backend/app/core/app_settings.py`.
# Non-secret assistant defaults now live in `Assistant-v2/lib/app_settings.py`.

# -----------------------------------------------------------------------------
# Core auth
# -----------------------------------------------------------------------------
SECRET_KEY=change-this-secret-before-production
JWT_ALGORITHM=HS256
JWT_PUBLIC_KEY=

# -----------------------------------------------------------------------------
# Data stores
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/fastapi_db
ASSISTANT_DB_URL=postgresql://postgres:postgres@127.0.0.1:5433/ai_assistant
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
ASSISTANT_AUTO_MIGRATE=true

# -----------------------------------------------------------------------------
# AI provider secrets and runtime endpoints
# -----------------------------------------------------------------------------
AI_API_KEY=replace_me
AI_API_BASE=https://api.siliconflow.com/v1
BACKEND_API_BASE_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Public URLs
# -----------------------------------------------------------------------------
LOGIN_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
FRONTEND_PORT=5173
BACKEND_ORIGIN=http://backend:8000
ASSISTANT_ORIGIN=http://assistant:8500
AURA_API_BASE_URL=/__backend__
AURA_ASSISTANT_BASE_URL=/__assistant__

# -----------------------------------------------------------------------------
# Email delivery
# -----------------------------------------------------------------------------
EMAIL_TRANSPORT=mailjet_api
EMAIL_SENDER_EMAIL=notifications@example.com
EMAIL_SENDER_NAME=VALID8 Notifications
EMAIL_REPLY_TO=notifications@example.com
MAILJET_API_KEY=
MAILJET_API_SECRET=

# -----------------------------------------------------------------------------
# Operational overrides
# -----------------------------------------------------------------------------
UVICORN_WORKERS=2
AURA_API_TIMEOUT_MS=15000
