# Aura — Production Environment
# Copy to .env on your server and fill in all required values.
# Lines marked "required" will cause the stack to refuse to start if missing.

# =============================================================================
# Secrets
# =============================================================================

# required — use a long random string, e.g.: openssl rand -hex 32
SECRET_KEY=

# required — your AI provider credentials
AI_API_KEY=
AI_API_BASE=
AI_MODEL=
AI_MAX_TOKENS=8192

# =============================================================================
# Database
# =============================================================================

# required — Postgres credentials (used by the db container and all services)
DB_USER=postgres
DB_PASSWORD=
DB_NAME=fastapi_db

# =============================================================================
# URLs — set these to your server's public IP or domain
# =============================================================================

# required — public URL of your frontend (no trailing slash)
# Example: http://203.0.113.10  or  https://aura.example.com
LOGIN_URL=
CORS_ALLOWED_ORIGINS=

# required — public URL of your backend API (no trailing slash)
# Example: http://203.0.113.10:8000  or  https://api.aura.example.com
BACKEND_ORIGIN=
BACKEND_API_BASE_URL=

# optional — public URL of the assistant service
ASSISTANT_ORIGIN=

# =============================================================================
# Workers
# =============================================================================

# Number of Uvicorn worker processes for the backend. 2–4 is typical for a
# small EC2 instance (t3.medium or larger).
UVICORN_WORKERS=2

# =============================================================================
# Email
# =============================================================================

# Set to mailjet_api to enable email delivery, or leave as disabled.
EMAIL_TRANSPORT=disabled
EMAIL_SENDER_EMAIL=notifications@example.com
EMAIL_SENDER_NAME=Aura Notifications
EMAIL_REPLY_TO=notifications@example.com

# required if EMAIL_TRANSPORT=mailjet_api
MAILJET_API_KEY=
MAILJET_API_SECRET=

# required if EMAIL_TRANSPORT=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_USE_TLS=false
SMTP_USE_STARTTLS=true
SMTP_USERNAME=
SMTP_PASSWORD=

# =============================================================================
# Optional
# =============================================================================

JWT_ALGORITHM=HS256
JWT_PUBLIC_KEY=
PRIVILEGED_FACE_VERIFICATION_ENABLED=true
ASSISTANT_AUTO_MIGRATE=true
