# =============================================================================
# SECURE PRODUCTION ENVIRONMENT TEMPLATE
# =============================================================================
# CRITICAL: Never commit the actual .env file with real credentials!
# This is a secure template. Copy to .env and fill with real values.
# =============================================================================

# -----------------------------------------------------------------------------
# Core Authentication - REQUIRED
# -----------------------------------------------------------------------------
# Generate with: openssl rand -hex 32
SECRET_KEY=REPLACE_WITH_STRONG_SECRET_KEY_MINIMUM_32_CHARS

JWT_ALGORITHM=HS256
JWT_PUBLIC_KEY=
PRIVILEGED_FACE_VERIFICATION_ENABLED=true

# -----------------------------------------------------------------------------
# Database - REQUIRED
# -----------------------------------------------------------------------------
DB_HOST=postgres
DB_PORT=5432
DB_NAME=aura_production
DB_USER=aura_user
# Generate with: openssl rand -base64 32
DB_PASSWORD=REPLACE_WITH_STRONG_DATABASE_PASSWORD

DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}
ASSISTANT_DB_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/ai_assistant

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
ASSISTANT_AUTO_MIGRATE=false

# -----------------------------------------------------------------------------
# AI Provider - REQUIRED
# -----------------------------------------------------------------------------
AI_API_KEY=REPLACE_WITH_YOUR_AI_API_KEY
AI_API_BASE=REPLACE_WITH_YOUR_AI_PROVIDER_URL
AI_MODEL=REPLACE_WITH_YOUR_MODEL_NAME
BACKEND_API_BASE_URL=https://your-backend-domain.com

# -----------------------------------------------------------------------------
# Public URLs - REQUIRED
# -----------------------------------------------------------------------------
LOGIN_URL=https://your-frontend-domain.com
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com
FRONTEND_PORT=80
BACKEND_ORIGIN=https://your-backend-domain.com
ASSISTANT_ORIGIN=https://your-assistant-domain.com
AURA_API_BASE_URL=/__backend__
AURA_ASSISTANT_BASE_URL=/__assistant__

# -----------------------------------------------------------------------------
# Email Delivery - REQUIRED for production
# -----------------------------------------------------------------------------
EMAIL_TRANSPORT=mailjet_api
EMAIL_SENDER_EMAIL=noreply@your-verified-domain.com
EMAIL_SENDER_NAME=Aura Notifications
EMAIL_REPLY_TO=support@your-verified-domain.com

# Get from https://app.mailjet.com/account/api_keys
MAILJET_API_KEY=REPLACE_WITH_YOUR_MAILJET_API_KEY
MAILJET_API_SECRET=REPLACE_WITH_YOUR_MAILJET_API_SECRET

# -----------------------------------------------------------------------------
# Security Settings - REQUIRED for production
# -----------------------------------------------------------------------------
API_DOCS_ENABLED=false
TRUSTED_HOSTS=your-backend-domain.com,your-frontend-domain.com
RATE_LIMIT_ENABLED=true
RATE_LIMIT_FAIL_OPEN=false

# -----------------------------------------------------------------------------
# Operational Settings
# -----------------------------------------------------------------------------
UVICORN_WORKERS=4

# -----------------------------------------------------------------------------
# pgAdmin - SECURE THESE CREDENTIALS
# -----------------------------------------------------------------------------
# Generate strong password with: openssl rand -base64 24
PGADMIN_EMAIL=admin@your-domain.com
PGADMIN_PASSWORD=REPLACE_WITH_STRONG_PGADMIN_PASSWORD

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
AURA_API_TIMEOUT_MS=15000
