# =============================================================================
# AURA V3 SEEDER CONFIGURATION (.env.seed.example -> .env)
# =============================================================================
# Copy the desired variables from this file into your main .env to override
# the default seeding behavior.
# 
# The Seeder relies inherently on the DATABASE_URL defined in your root .env 
# to determine the target connection.
# =============================================================================

# Target Database
# Inherits DATABASE_URL from your primary Backend .env automatically

# Platform Admin
SEED_ADMIN_EMAIL=admin@aura.com
SEED_ADMIN_PASSWORD=AdminPass123!

# Global Configuration

# Database Seeding Controls (Deterministic & Stochastic)
SEED_DATABASE=false          # Set to true only if executing seeder via app startup hook
SEED_WIPE_EXISTING=true      # Empties all tables before inserting dummy data
SEED_RANDOMIZER_KEY=42       # Change this to generate a different deterministic universe
SEED_UNIQUE_PASSWORDS=false  # True generates unique hash per student, false binds 'Student123!' uniformly
SEED_USER_SUFFIX_PROBABILITY=0.3
SEED_CREDENTIALS_FORMAT=csv  # Formats: csv, tsv, psv (defaults to csv)
SEED_N_SCHOOLS=5

# Stochastic Range Controls (Defines the min/max size of generated entities)
SEED_MIN_STUDENTS=50
SEED_MAX_STUDENTS=250
SEED_MIN_EVENTS=30
SEED_MAX_EVENTS=100
SEED_MIN_COLLEGES=3
SEED_MAX_COLLEGES=8
SEED_MIN_PROGRAMS=1

# Temporal Controls (Deterministic Random Dates)
# Format: MM,DD,YYYY
SEED_START_MMDDYY=1,1,2024
SEED_END_MMDDYY=12,31,2026
