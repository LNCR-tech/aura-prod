# Copy this file to Backend/.env for local development.
# Replace placeholder secrets, emails, and OAuth tokens before using outbound email.

# Local backend development settings.
# Docker Compose service environment variables override these values inside containers.

DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/fastapi_db
DATABASE_ADMIN_URL=postgresql://postgres:postgres@127.0.0.1:5433/postgres
SECRET_KEY=change-this-secret-before-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!

DB_POOL_SIZE=10
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT_SECONDS=15
DB_POOL_RECYCLE_SECONDS=1800

CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
CELERY_TASK_TIME_LIMIT_SECONDS=10800

AUTH_ENABLE_MFA=false
FACE_SCAN_BYPASS_EMAILS=
FACE_THRESHOLD_SINGLE=0.40
FACE_THRESHOLD_GROUP=0.40
FACE_THRESHOLD_MFA=0.35
FACE_EMBEDDING_DIM=512
FACE_EMBEDDING_DTYPE=float32
LIVENESS_THRESHOLD=0.85
ALLOW_LIVENESS_BYPASS_WHEN_MODEL_MISSING=false
ANTI_SPOOF_SCALE=2.7
ANTI_SPOOF_MODEL_PATH=
GEO_MAX_ALLOWED_ACCURACY_M=30
GEO_MAX_TRAVEL_SPEED_MPS=60

EVENT_STATUS_SYNC_ENABLED=true
EVENT_STATUS_SYNC_INTERVAL_SECONDS=60
PUBLIC_ATTENDANCE_ENABLED=true
PUBLIC_ATTENDANCE_MAX_FACES_PER_FRAME=10
PUBLIC_ATTENDANCE_SCAN_COOLDOWN_SECONDS=8
PUBLIC_ATTENDANCE_EVENT_LOOKAHEAD_HOURS=12
TENANT_DATABASE_PREFIX=school

IMPORT_MAX_FILE_SIZE_MB=50
IMPORT_CHUNK_SIZE=5000
IMPORT_STORAGE_DIR=storage/imports
IMPORT_RATE_LIMIT_COUNT=3
IMPORT_RATE_LIMIT_WINDOW_SECONDS=300

# Set EMAIL_TRANSPORT=gmail_api and populate the Google OAuth values below to enable outbound mail.
EMAIL_TRANSPORT=disabled
EMAIL_REQUIRED_ON_STARTUP=false
EMAIL_VERIFY_CONNECTION_ON_STARTUP=false
EMAIL_TIMEOUT_SECONDS=20
EMAIL_SENDER_EMAIL=notifications@example.com
EMAIL_FROM_EMAIL=notifications@example.com
EMAIL_FROM_NAME=VALID8 Notifications
EMAIL_REPLY_TO=notifications@example.com
EMAIL_GOOGLE_ACCOUNT_TYPE=personal
EMAIL_GOOGLE_ALLOW_CUSTOM_FROM=false
GOOGLE_GMAIL_API_BASE_URL=https://gmail.googleapis.com/gmail/v1
GOOGLE_OAUTH_AUTH_URL=https://accounts.google.com/o/oauth2/auth
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_OAUTH_REFRESH_TOKEN=your-google-oauth-refresh-token
GOOGLE_OAUTH_SCOPES=https://www.googleapis.com/auth/gmail.send,https://www.googleapis.com/auth/gmail.settings.basic
GOOGLE_OAUTH_TOKEN_URL=https://oauth2.googleapis.com/token

LOGIN_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

SCHOOL_LOGO_STORAGE_DIR=storage/school_logos
SCHOOL_LOGO_MAX_FILE_SIZE_MB=2
SCHOOL_LOGO_PUBLIC_PREFIX=/media/school-logos
