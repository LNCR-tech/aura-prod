{
  "name": "aura-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "node ./scripts/lint.mjs",
    "test": "node --test ./scripts/smoke.test.mjs",
    "cap:config": "node ./scripts/write-capacitor-config.mjs",
    "cap:sync": "npm run cap:config && npx cap sync",
    "android:sync": "npm run build && npm run cap:config && npx cap sync android",
    "android:open": "npm run cap:config && npx cap open android",
    "android:build:debug": "npm run android:sync && cd android && gradlew.bat assembleDebug",
    "android:build:release": "npm run android:sync && cd android && gradlew.bat assembleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/camera": "^8.0.2",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/geolocation": "^8.1.0",
    "@capacitor/haptics": "^8.0.1",
    "@capacitor/keyboard": "^8.0.2",
    "@capacitor/network": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@lottiefiles/dotlottie-vue": "^0.11.10",
    "@mediapipe/tasks-vision": "^0.10.32",
    "chart.js": "^4.5.1",
    "dompurify": "^3.4.0",
    "highlight.js": "^11.11.1",
    "jspdf": "^4.2.1",
    "katex": "^0.16.45",
    "leaflet": "^1.9.4",
    "lucide-vue-next": "^0.577.0",
    "marked": "^18.0.0",
    "marked-highlight": "^2.2.4",
    "marked-katex-extension": "^5.1.8",
    "pinia": "^3.0.4",
    "vue": "^3.5.25",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "tailwindcss": "^4.2.1",
    "vite": "^7.3.1"
  }
}
