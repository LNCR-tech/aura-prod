# assistant/.env.example
# Copy this file to .env and fill in all values.
#
# Variable types:
#
#   [BEHAVIOR] Controls how this service behaves. Only this service reads it.
#              Independent — nothing else depends on this value.
#
#
#   [IDENTITY] Credentials or secrets that define who this service is.
#              Independent — you choose them, but other services may need to copy them into their own [NEIGHBOR] variables.
#
#
#   [SELF]     This service's own address or port.
#              You choose the value, but other services must match it.
#
#
#   [NEIGHBOR] URL or address of another service this service talks to.
#              Dependent — must match the target service's [SELF] or [IDENTITY].




# --- AI Provider ---
# [IDENTITY] API key for the AI provider. Only the assistant uses this.
AI_API_KEY=<your-ai-api-key>

# [BEHAVIOR] Which AI provider endpoint and model to use.
AI_API_BASE=https://api.groq.com/openai/v1
AI_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
AI_MAX_TOKENS=8192

# --- Database ---
# [NEIGHBOR] Must match POSTGRES_USER, POSTGRES_PASSWORD, and DB_PORT in database/.env.
ASSISTANT_DB_URL=postgresql://<user>:<password>@<host>:5432/ai_assistant

# --- Backend Integration ---
# [NEIGHBOR] Must match BACKEND_API_BASE_URL in backend/.env.
BACKEND_API_BASE_URL=http://localhost:8000

# --- Auth ---
# [IDENTITY] Must be identical to SECRET_KEY in backend/.env.
#            Both services use it to verify JWTs issued by the backend.
SECRET_KEY=<same SECRET_KEY as backend>

# [BEHAVIOR] JWT algorithm. Must match backend.
JWT_ALGORITHM=HS256

# --- CORS ---
# [SELF] This assistant's own public URL.
ASSISTANT_ORIGIN=http://localhost:8500

# [NEIGHBOR] Must match the frontend's actual URL.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Migrations ---
# [BEHAVIOR] Whether the assistant auto-creates its DB tables on startup.
#            Set to false in production and manage schema manually.
ASSISTANT_AUTO_MIGRATE=true
