# assistant/.env.example
# Copy this file to .env and fill in all values.
#
# Variable types:
#   [FREE]     Set to whatever you want. No other service references this.
#   [REQUIRED] This service needs it to function. Must be set.
#   [CONTRACT] Set to whatever you want, but other services must match.
#              If you change it here, update the referencing services too.

# --- AI Provider ---
# [FREE] Only the assistant reads these. Use any OpenAI-compatible provider.
AI_API_KEY=<your-ai-api-key>
AI_API_BASE=https://api.groq.com/openai/v1
AI_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
AI_MAX_TOKENS=8192

# --- Database ---
# [CONTRACT] Must match POSTGRES_USER, POSTGRES_PASSWORD, and DB_PORT in database/.env.
#            The database name (ai_assistant) must exist — created by docker-init/init.sql.
ASSISTANT_DB_URL=postgresql://<user>:<password>@<host>:5432/ai_assistant

# --- Backend Integration ---
# [CONTRACT] Must match BACKEND_API_BASE_URL in backend/.env.
#            The assistant calls the backend API using this URL.
BACKEND_API_BASE_URL=http://localhost:8000

# --- Auth ---
# [CONTRACT] Must be identical to SECRET_KEY in backend/.env.
#            Both services use it to verify JWTs issued by the backend.
SECRET_KEY=<same SECRET_KEY as backend>

# [FREE] JWT algorithm — must match backend but is effectively always HS256.
JWT_ALGORITHM=HS256

# --- CORS ---
# [CONTRACT] CORS_ALLOWED_ORIGINS must match the frontend's actual URL.
ASSISTANT_ORIGIN=http://localhost:8500
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Migrations ---
# [FREE] Whether the assistant auto-creates its DB tables on startup.
#        Set to false in production and manage schema manually.
ASSISTANT_AUTO_MIGRATE=true
