# Assistant environment variables
# Copy this file to .env and fill in all values

# --- AI Provider ---
AI_API_KEY=<your-ai-api-key>
AI_API_BASE=https://api.groq.com/openai/v1
AI_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
AI_MAX_TOKENS=8192

# --- Database ---
ASSISTANT_DB_URL=postgresql://<user>:<password>@<host>:5432/<dbname>

# --- Backend Integration ---
BACKEND_API_BASE_URL=http://localhost:8000

# --- Auth ---
SECRET_KEY=<same SECRET_KEY as backend>
JWT_ALGORITHM=HS256

# --- CORS ---
ASSISTANT_ORIGIN=http://localhost:8500
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Migrations ---
ASSISTANT_AUTO_MIGRATE=true
