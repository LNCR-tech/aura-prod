# backend/.env.example
# Copy this file to .env and fill in all values.
#
# Variable types:
#   [FREE]     Set to whatever you want. No other service references this.
#   [REQUIRED] This service needs it to function. Must be set.
#   [CONTRACT] Set to whatever you want, but other services must match.
#              If you change it here, update the referencing services too.

# --- Security ---
# [CONTRACT] SECRET_KEY must be identical in assistant/.env — both services
#            use it to sign and verify JWTs.
SECRET_KEY=<generate: openssl rand -hex 32>

# [FREE] JWT algorithm — only the backend reads this.
JWT_ALGORITHM=HS256
JWT_PUBLIC_KEY=

# --- Admin Bootstrap ---
# [FREE] Platform admin account created on first bootstrap run.
DEFAULT_ADMIN_EMAIL=admin@yourdomain.com
DEFAULT_ADMIN_PASSWORD=<strong-password>

# --- Database ---
# [CONTRACT] Must match POSTGRES_USER, POSTGRES_PASSWORD, and DB_PORT in database/.env.
#            The database name (fastapi_db) must exist — created by docker-init/init.sql.
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/fastapi_db

# --- Redis / Celery ---
# [CONTRACT] Must point to the same Redis instance used by worker and beat services.
CELERY_BROKER_URL=redis://<host>:6379/0
CELERY_RESULT_BACKEND=redis://<host>:6379/0

# --- CORS & Hosts ---
# [CONTRACT] LOGIN_URL and CORS_ALLOWED_ORIGINS must match the frontend's actual URL.
#            BACKEND_API_BASE_URL must match the backend's actual URL — assistant uses this.
LOGIN_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173
BACKEND_API_BASE_URL=http://localhost:8000

# --- Email ---
# [FREE] Email transport and sender settings. No other service reads these.
EMAIL_TRANSPORT=disabled
# Options: disabled | smtp | mailjet_api
EMAIL_SENDER_EMAIL=notifications@yourdomain.com
EMAIL_SENDER_NAME=Aura Notifications
EMAIL_REPLY_TO=notifications@yourdomain.com

# [FREE] SMTP settings (for local dev with Mailpit).
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USE_TLS=false
SMTP_USE_STARTTLS=false
SMTP_USERNAME=
SMTP_PASSWORD=

# [FREE] Mailjet credentials (for production email).
MAILJET_API_KEY=<your-mailjet-api-key>
MAILJET_API_SECRET=<your-mailjet-api-secret>

# --- Feature Flags ---
# [FREE] All feature flags are only read by the backend.
API_DOCS_ENABLED=true
RATE_LIMIT_ENABLED=false
RATE_LIMIT_FAIL_OPEN=true
FACE_SCAN_BYPASS_ALL=true
PRIVILEGED_FACE_VERIFICATION_ENABLED=false

# --- Workers ---
# [FREE] Number of Uvicorn worker processes.
UVICORN_WORKERS=1
