# backend/.env.example
# Copy this file to .env and fill in all values.
#
# Variable types:
#
#   [BEHAVIOR] Controls how this service behaves. Only this service reads it.
#              Independent — nothing else depends on this value.
#
#
#   [IDENTITY] Credentials or secrets that define who this service is.
#              Independent — you choose them, but other services may need to
#              copy them into their own [NEIGHBOR] variables.
#
#
#   [ENDPOINT] This service's own address or port that other services connect to.
#              You choose the value, but other services must match it.
#
#
#   [NEIGHBOR] URL or address of another service this service talks to.
#              Dependent — must match the target service's [ENDPOINT] or [IDENTITY].

# =============================================================================
# QUICK SETUP
# =============================================================================
#
# Docker (docker compose --profile dev up --build):
#
#   Required:
#     SECRET_KEY=<generate: openssl rand -hex 32>
#     DATABASE_URL=postgresql://postgres:<password>@postgres:5432/fastapi_db
#     CELERY_BROKER_URL=redis://redis:6379/0
#     CELERY_RESULT_BACKEND=redis://redis:6379/0
#
#   Optional (has working defaults):
#     DEFAULT_ADMIN_EMAIL=admin@yourdomain.com
#     DEFAULT_ADMIN_PASSWORD=<strong-password>
#     EMAIL_TRANSPORT=disabled
#     UVICORN_WORKERS=1
#
# Manual (uvicorn app.main:app --reload):
#
#   Required:
#     SECRET_KEY=<generate: openssl rand -hex 32>
#     DATABASE_URL=postgresql://postgres:<password>@127.0.0.1:5432/fastapi_db
#     CELERY_BROKER_URL=redis://127.0.0.1:6379/0
#     CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
#     LOGIN_URL=http://localhost:5173
#     CORS_ALLOWED_ORIGINS=http://localhost:5173
#
#   Optional (has working defaults):
#     DEFAULT_ADMIN_EMAIL=admin@yourdomain.com
#     DEFAULT_ADMIN_PASSWORD=<strong-password>
#     EMAIL_TRANSPORT=disabled
#     UVICORN_WORKERS=1
#
# =============================================================================


# --- Security ---

# [IDENTITY] Must be identical in assistant/.env — both services use it to sign
#            and verify JWTs.
SECRET_KEY=<generate: openssl rand -hex 32>

# [BEHAVIOR] JWT algorithm. Effectively always HS256 unless using RS256 with a key pair.
JWT_ALGORITHM=HS256
JWT_PUBLIC_KEY=

# --- Admin Bootstrap ---

# [IDENTITY] Platform admin account created on first bootstrap run.
DEFAULT_ADMIN_EMAIL=admin@yourdomain.com
DEFAULT_ADMIN_PASSWORD=<strong-password>

# --- Database ---

# [NEIGHBOR] Must match POSTGRES_USER, POSTGRES_PASSWORD, and DB_PORT in database/.env.
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/fastapi_db

# --- Redis / Celery ---

# [NEIGHBOR] Must point to the same Redis instance used by worker and beat services.
CELERY_BROKER_URL=redis://<host>:6379/0
CELERY_RESULT_BACKEND=redis://<host>:6379/0

# --- CORS & Hosts ---

# [NEIGHBOR] Must match the frontend's actual URL.
LOGIN_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173

# [ENDPOINT] This backend's own public URL. assistant/.env must reference this.
BACKEND_API_BASE_URL=http://localhost:8000

# --- Email ---

# [BEHAVIOR] Which transport to use: disabled | smtp | mailjet_api
EMAIL_TRANSPORT=disabled

# [IDENTITY] Sender identity shown in outgoing emails.
EMAIL_SENDER_EMAIL=notifications@yourdomain.com
EMAIL_SENDER_NAME=Aura Notifications
EMAIL_REPLY_TO=notifications@yourdomain.com

# [NEIGHBOR] SMTP server (for local dev with Mailpit).
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USE_TLS=false
SMTP_USE_STARTTLS=false
SMTP_USERNAME=
SMTP_PASSWORD=

# [IDENTITY] Mailjet API credentials (for production email).
MAILJET_API_KEY=<your-mailjet-api-key>
MAILJET_API_SECRET=<your-mailjet-api-secret>

# --- Feature Flags ---

# [BEHAVIOR] All flags below only affect backend behavior.
API_DOCS_ENABLED=true
RATE_LIMIT_ENABLED=false
RATE_LIMIT_FAIL_OPEN=true
FACE_SCAN_BYPASS_ALL=true
PRIVILEGED_FACE_VERIFICATION_ENABLED=false

# --- Workers ---

# [BEHAVIOR] Number of Uvicorn worker processes.
UVICORN_WORKERS=1
