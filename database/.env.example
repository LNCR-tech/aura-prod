# database/.env.example
# Copy this file to .env and fill in all values.
#
# Variable types:
#
#   [BEHAVIOR] Controls how this service behaves. Only this service reads it.
#              Independent — nothing else depends on this value.
#
#
#   [IDENTITY] Credentials or secrets that define who this service is.
#              Independent — you choose them, but other services may need to
#              copy them into their own [NEIGHBOR] variables.
#
#
#   [ENDPOINT]  This service's own address or port that other services connect to.
#              You choose the value, but other services must match it.
#
#
#   [NEIGHBOR] URL or address of another service this service talks to.
#              Dependent — must match the target service's [ENDPOINT] or [IDENTITY].

# =============================================================================
# QUICK SETUP
# =============================================================================
#
# Docker (docker compose --profile dev up --build):
#
#   Required:
#     POSTGRES_PASSWORD=<strong-password>
#
#   Optional (has working defaults):
#     POSTGRES_USER=postgres
#     DB_PORT=5432
#     PGADMIN_DEFAULT_EMAIL=admin@aura.local
#     PGADMIN_DEFAULT_PASSWORD=changeme
#
# Manual (just have Postgres running locally):
#
#   Required:
#     POSTGRES_PASSWORD=<strong-password>
#
#   Optional (has working defaults):
#     POSTGRES_USER=postgres
#     DB_PORT=5432
#
# Both databases (fastapi_db, ai_assistant) are created automatically
# by docker-init/init.sql on first container startup.
#
# =============================================================================


# [IDENTITY] Postgres credentials. backend and assistant must use these
#            in their DATABASE_URL / ASSISTANT_DB_URL connection strings.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<strong-password>

# [ENDPOINT] The port Postgres listens on. backend and assistant connection
#        strings must use this port.
DB_PORT=5432

# [IDENTITY] pgAdmin login credentials.
PGADMIN_DEFAULT_EMAIL=admin@aura.local
PGADMIN_DEFAULT_PASSWORD=<strong-password>
