# database/.env.example
# Copy this file to .env and fill in all values.
#
# Variable types:
#   [FREE]     Set to whatever you want. No other service references this.
#   [REQUIRED] This service needs it to function. Must be set.
#   [CONTRACT] Set to whatever you want, but other services must match.
#              If you change it here, update the referencing services too.
#
# Both databases (fastapi_db, ai_assistant) are created automatically
# by database/docker-init/init.sql on first container startup.

# [CONTRACT] Postgres credentials — backend and assistant must use these
#            in their DATABASE_URL / ASSISTANT_DB_URL connection strings.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<strong-password>

# [CONTRACT] Postgres port — backend and assistant connection strings must use this port.
DB_PORT=5432

# [FREE] pgAdmin login — only used by the pgAdmin UI, no other service references this.
PGADMIN_DEFAULT_EMAIL=admin@aura.local
PGADMIN_DEFAULT_PASSWORD=<strong-password>
