# database/.env.example
# Copy this file to .env and fill in all values.
#
# Variable types:
#   [BEHAVIOR] Controls how this service behaves. Only this service reads it.
#   [IDENTITY] Credentials or secrets that define who this service is.
#   [SELF]     This service's own address/port. Other services must reference this.
#   [NEIGHBOR] URL or address of another service that this service talks to.
#
# Both databases (fastapi_db, ai_assistant) are created automatically
# by database/docker-init/init.sql on first container startup.

# [IDENTITY] Postgres credentials. backend and assistant must use these
#            in their DATABASE_URL / ASSISTANT_DB_URL connection strings.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<strong-password>

# [SELF] The port Postgres listens on. backend and assistant connection
#        strings must use this port.
DB_PORT=5432

# [IDENTITY] pgAdmin login credentials.
PGADMIN_DEFAULT_EMAIL=admin@aura.local
PGADMIN_DEFAULT_PASSWORD=<strong-password>
