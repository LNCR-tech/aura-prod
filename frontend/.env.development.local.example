# Copy this file to `.env.development.local` for local frontend-only development.
#
# Vite loads this file when you run:
#   npm run dev
#
# Keep this file local-only. Do not commit machine-specific values in
# `.env.development.local`.

# Required for the current Vite dev proxy setup.
VITE_BACKEND_PROXY_TARGET=http://127.0.0.1:8000

# Optional frontend overrides.
VITE_API_BASE_URL=/__backend__
VITE_API_TIMEOUT_MS=15000
VITE_ASSISTANT_PROXY_TARGET=http://127.0.0.1:8500
VITE_ASSISTANT_BASE_URL=http://127.0.0.1:8500
