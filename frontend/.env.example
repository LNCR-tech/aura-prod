# frontend/.env.example
# Copy this file to .env and fill in all values.
#
# Variable types:
#
#   [BEHAVIOR] Controls how this service behaves. Only this service reads it.
#              Independent — nothing else depends on this value.
#
#
#   [IDENTITY] Credentials or secrets that define who this service is.
#              Independent — you choose them, but other services may need to
#              copy them into their own [NEIGHBOR] variables.
#
#
#   [SELF]     This service's own address or port.
#              You choose the value, but other services must match it.
#
#
#   [NEIGHBOR] URL or address of another service this service talks to.
#              Dependent — must match the target service's [SELF] or [IDENTITY].
#
# There are two kinds of variables here:
#   VITE_*  — build-time variables, baked into the JS bundle by Vite at build time.
#   Others  — runtime variables, injected by nginx at container startup via
#             nginx.conf.template and runtime-config.js.template.
#             These only take effect inside the Docker container.

# =============================================================================
# QUICK SETUP
# =============================================================================
#
# Docker (docker compose --profile dev up --build):
#
#   Required:
#     BACKEND_ORIGIN=http://backend:8000
#
#   Optional (has working defaults):
#     AURA_API_BASE_URL=/__backend__/
#     AURA_API_TIMEOUT_MS=15000
#     AURA_PORT=80
#
# Manual (npm run dev):
#
#   Required:
#     VITE_API_BASE_URL=http://localhost:8000
#     VITE_ASSISTANT_BASE_URL=http://localhost:8500
#
#   Optional (has working defaults):
#     VITE_API_TIMEOUT_MS=15000
#
# =============================================================================


# =============================================================================
# VITE BUILD-TIME VARIABLES
# =============================================================================

# [NEIGHBOR] Backend API base URL used by Vite during local dev (npm run dev).
#            Must match BACKEND_API_BASE_URL in backend/.env.
#            In Docker, nginx proxies /__backend__/ instead — see AURA_API_BASE_URL below.
VITE_API_BASE_URL=http://localhost:8000

# [BEHAVIOR] Request timeout in milliseconds for API calls.
VITE_API_TIMEOUT_MS=15000

# [NEIGHBOR] Assistant base URL. Must match ASSISTANT_ORIGIN in assistant/.env.
VITE_ASSISTANT_BASE_URL=http://localhost:8500


# =============================================================================
# NGINX RUNTIME VARIABLES (Docker only)
# =============================================================================

# [NEIGHBOR] The backend's actual URL that nginx proxies to.
#            Requests to /__backend__/ inside the container are forwarded here.
#            Must match the backend's actual host and port.
BACKEND_ORIGIN=http://backend:8000

# [BEHAVIOR] The API base URL exposed to the frontend inside Docker.
#            Set to /__backend__/ so nginx handles the proxy transparently.
AURA_API_BASE_URL=/__backend__/

# [BEHAVIOR] Request timeout in milliseconds used by the nginx runtime config.
AURA_API_TIMEOUT_MS=15000

# [SELF] The port the nginx container listens on.
#        Update docker-compose.yml ports mapping if you change this.
AURA_PORT=80
