# frontend/.env.example
# Copy this file to .env and fill in all values.
#
# Variable types:
#   [BEHAVIOR] Controls how this service behaves. Only this service reads it.
#   [IDENTITY] Credentials or secrets that define who this service is.
#   [SELF]     This service's own address/port. Other services must reference this.
#   [NEIGHBOR] URL or address of another service that this service talks to.

# --- Backend ---
# [NEIGHBOR] Must match BACKEND_API_BASE_URL in backend/.env.
VITE_API_BASE_URL=http://localhost:8000

# [BEHAVIOR] Request timeout in milliseconds.
VITE_API_TIMEOUT_MS=15000

# --- Assistant ---
# [NEIGHBOR] Must match ASSISTANT_ORIGIN in assistant/.env.
VITE_ASSISTANT_BASE_URL=http://localhost:8500

# --- Docker ---
# [SELF] The port this frontend container exposes. Update docker-compose.yml
#        ports mapping if you change this.
FRONTEND_PORT=5173
