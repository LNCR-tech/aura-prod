# frontend/.env.example
# Copy this file to .env and fill in all values.
#
# Variable types:
#   [FREE]     Set to whatever you want. No other service references this.
#   [REQUIRED] This service needs it to function. Must be set.
#   [CONTRACT] Set to whatever you want, but other services must match.
#              If you change it here, update the referencing services too.

# --- Backend ---
# [CONTRACT] Must match BACKEND_API_BASE_URL in backend/.env and
#            the backend's actual host/port.
VITE_API_BASE_URL=http://localhost:8000

# [FREE] Request timeout in milliseconds. Only the frontend reads this.
VITE_API_TIMEOUT_MS=15000

# --- Assistant ---
# [CONTRACT] Must match ASSISTANT_ORIGIN in assistant/.env and
#            the assistant's actual host/port.
VITE_ASSISTANT_BASE_URL=http://localhost:8500

# --- Docker ---
# [CONTRACT] The port the frontend container exposes. If you change this,
#            update the ports mapping in docker-compose.yml as well.
FRONTEND_PORT=5173
