# seeder/.env.example
# Copy this file to .env and fill in all values.
#
# Variable types:
#
#   [BEHAVIOR] Controls how this service behaves. Only this service reads it.
#              Independent — nothing else depends on this value.
#
#
#   [IDENTITY] Credentials or secrets that define who this service is.
#              Independent — you choose them, but other services may need to
#              copy them into their own [NEIGHBOR] variables.
#
#
#   [SELF]     This service's own address or port.
#              You choose the value, but other services must match it.
#
#
#   [NEIGHBOR] URL or address of another service this service talks to.
#              Dependent — must match the target service's [SELF] or [IDENTITY].
#
# The seeder's own configuration (schools, students, events, etc.) lives in
# variables.py — not here. See variables.py for those settings.

# =============================================================================
# QUICK SETUP
# =============================================================================
#
# Docker (docker compose --profile dev up --build):
#
#   Required:
#     DATABASE_URL=postgresql://postgres:<password>@postgres:5432/fastapi_db
#     SEED_DATABASE=true
#     SEED_CONFIRM=yes
#
#   Optional (has working defaults):
#     SEED_WIPE_EXISTING=true
#
# Manual (python seed.py demo):
#
#   Required:
#     DATABASE_URL=postgresql://postgres:<password>@127.0.0.1:5432/fastapi_db
#     SEED_DATABASE=true
#     SEED_CONFIRM=yes
#
#   Optional (has working defaults):
#     SEED_WIPE_EXISTING=true
#
# =============================================================================


# [NEIGHBOR] Must match DATABASE_URL in backend/.env and the Postgres credentials
#            in database/.env. The seeder reads and writes directly to this database.
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/fastapi_db

# [BEHAVIOR] Safety gate — set to true to enable seeding. Default is false.
#            Must also set SEED_CONFIRM=yes or the seeder will refuse to run.
SEED_DATABASE=false

# [BEHAVIOR] Confirmation gate — must be set to 'yes' alongside SEED_DATABASE=true.
#            Prevents accidental wipes.
SEED_CONFIRM=

# [BEHAVIOR] Whether to wipe existing data before seeding. Default is true.
#            Set to false to add data on top of existing records.
SEED_WIPE_EXISTING=true
